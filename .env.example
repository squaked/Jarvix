# Override data directory for memory, chats, and settings.json (defaults to ./.jarvix-data, or existing ./.jarvis-data).
# Legacy: JARVIS_DATA_DIR is still honored if set.
JARVIX_DATA_DIR=

# Force writable dir on Netlify/AWS Lambda-style hosts (normally auto-detected via AWS_* env vars).
# JARVIX_USE_TMP_DATA_DIR=true

# Optional: single shared Groq key for everyone hitting your deploy (billing + abuse risk). If unset,
# each visitor uses onboarding / their own BYOK key (recommended); keys are mirrored in the browser too.
# GROQ_API_KEY=

# Hosting note (Netlify free tier works for the app shell + API routes; “auth” here is BYOK only).
# Server-side chats, memory, and settings.json use the filesystem — on Netlify that maps to ephemeral
# /tmp tied to Lambda instances, so history can disappear or drift between requests. localhost or a
# VPS/container with a persistent disk gives reliable saves; macOS calendar/screenshot integrations
# only work when the Jarvix server runs on your Mac.
