scripts/macos/JarvixEventKitHelper/JarvixEventKitHelper.app/

# Generated by rebuild-app.sh with the correct INSTALL_DIR for each machine.
# Must not be tracked in git — git reset --hard would overwrite them with the
# dev machine path and break the installed app's server startup.
scripts/macos/launcher.sh
scripts/macos/quit-server.sh

