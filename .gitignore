# macOS EventKit helper (run npm run build:macos-helper)
scripts/macos/JarvixEventKitHelper/JarvixEventKitHelper.app/
# Persistent self-signed code-signing identity for the helper. Keeps the
# binary's CDHash stable across rebuilds so macOS TCC permission survives.
scripts/macos/JarvixEventKitHelper/.signing/

# Logs
/logs/